// END_NETFLOW_DATA

var string[] NF_TICKERS = na
var int[]    NF_TIDX  = na
var int[]    NF_TIME  = na
var float[]  NF_CALL  = na
var float[]  NF_PUT   = na
var float[]  NF_PRICE = na

var int   _start  = -1
var int   _end    = -1
var float _floMin = na
var float _floMax = na
var float _pxMin  = na
var float _pxMax  = na
var bool  _hasData = false

if barstate.isfirst
    [a, b, c, d, e, h] = f_nfData()
    NF_TICKERS := a
    NF_TIDX    := b
    NF_TIME    := c
    NF_CALL    := d
    NF_PUT     := e
    NF_PRICE   := h

if barstate.isfirst
    int ti = f_findTi(NF_TICKERS)
    [st, en] = f_findRange(NF_TIDX, ti)
    [fl1, fl2, p1, p2] = f_minmax(NF_CALL, NF_PUT, NF_PRICE, st, en)
    _start   := st
    _end     := en
    _floMin  := fl1
    _floMax  := fl2
    _pxMin   := p1
    _pxMax   := p2
    _hasData := st >= 0

[callV, putV, pxV] = f_sample(NF_TIME, NF_CALL, NF_PUT, NF_PRICE, _start, _end, time, _floMin, _floMax, _pxMin, _pxMax)

plot(showCall  ? callV : na, "Call net flow", color=colCall,  linewidth=lineW)
plot(showPut   ? putV  : na, "Put net flow",  color=colPut,   linewidth=lineW)
plot(showPrice ? pxV   : na, "Price (scaled)", color=colPrice, linewidth=1)
hline(0, "Zero", color=color.new(color.gray, 50), linestyle=hline.style_dotted)

plot(callV, "Call $ (raw)", display=display.data_window)
plot(putV,  "Put $ (raw)",  display=display.data_window)

var label _lbl = na
if barstate.islast
    if not na(_lbl)
        label.delete(_lbl)
    string txt = _hasData ? syminfo.ticker + " net flow · " + str.tostring(NF_ROLLING_DAYS) + "d · updated " + NF_UPDATED : "MHSG Net Flow: no data for " + syminfo.ticker
    _lbl := label.new(bar_index, _hasData and not na(_floMax) ? _floMax : 0, txt, style=label.style_label_left, color=color.new(color.gray, 25), textcolor=color.white, size=size.small)
