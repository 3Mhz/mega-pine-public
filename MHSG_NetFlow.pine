// MHSG Net Flow — intraday options net premium flow + price
//   Green = cumulative CALL net premium
//   Red   = cumulative PUT net premium
//   White = stock price (scaled onto the flow axis for shape comparison)
//
// Data is embedded below and only renders when the chart symbol matches
// an embedded ticker (same pattern as MHSG_DarkPool_Levels).
//
// IMPORTANT: use an INTRADAY timeframe (5–30 min) so bar times align with
// embedded flow timestamps.

//@version=6
indicator("MHSG Net Flow", shorttitle="NetFlow", overlay=false, format=format.volume, precision=0)

grp = "Net Flow"
showCall  = input.bool(true,  "Show call net flow (green)", group=grp)
showPut   = input.bool(true,  "Show put net flow (red)",    group=grp)
showPrice = input.bool(true,  "Show price (white, scaled)", group=grp)
colCall   = input.color(color.new(#26A69A, 0), "Call color",  group=grp)
colPut    = input.color(color.new(#EF5350, 0), "Put color",   group=grp)
colPrice  = input.color(color.new(#FFFFFF, 0), "Price color", group=grp)
lineW     = input.int(2, "Flow line width", minval=1, maxval=4, group=grp)

// ── Parse helpers (CSV string → typed array) ────────────────────────────
f_floatArr(string s) =>
    out = array.new_float()
    if str.length(s) > 0
        parts = str.split(s, ",")
        for i = 0 to array.size(parts) - 1
            out.push(str.tonumber(array.get(parts, i)))
    out

// Flow values are stored in $thousands; expand back to dollars.
f_floatArrK(string s) =>
    out = array.new_float()
    if str.length(s) > 0
        parts = str.split(s, ",")
        for i = 0 to array.size(parts) - 1
            out.push(str.tonumber(array.get(parts, i)) * 1000)
    out

f_intArr(string s) =>
    out = array.new_int()
    if str.length(s) > 0
        parts = str.split(s, ",")
        for i = 0 to array.size(parts) - 1
            out.push(int(str.tonumber(array.get(parts, i))))
    out

// Times are stored as minute-offsets from a base epoch; expand to ms.
f_timeArr(string s, int base) =>
    out = array.new_int()
    if str.length(s) > 0
        parts = str.split(s, ",")
        for i = 0 to array.size(parts) - 1
            out.push(base + int(str.tonumber(array.get(parts, i))) * 60000)
    out

f_strArr(string s) =>
    s == "" ? array.new_string() : str.split(s, ",")

// ── Logic helpers ───────────────────────────────────────────────────────
f_findTi(string[] tickers) =>
    string sym = str.upper(syminfo.ticker)
    int ti = -1
    for i = 0 to array.size(tickers) - 1
        if array.get(tickers, i) == sym
            ti := i
    ti

f_findRange(int[] tidx, int ti) =>
    int st = -1
    int en = -1
    if ti >= 0
        for r = 0 to array.size(tidx) - 1
            if array.get(tidx, r) == ti
                if st == -1
                    st := r
                en := r
    [st, en]

f_minmax(float[] call, float[] put, float[] price, int st, int en) =>
    float flMin = na
    float flMax = na
    float pMin  = na
    float pMax  = na
    if st >= 0
        for r = st to en
            float cv = array.get(call, r)
            float pv = array.get(put, r)
            float xv = array.get(price, r)
            flMin := na(flMin) ? math.min(cv, pv) : math.min(flMin, cv, pv)
            flMax := na(flMax) ? math.max(cv, pv) : math.max(flMax, cv, pv)
            pMin  := na(pMin)  ? xv : math.min(pMin, xv)
            pMax  := na(pMax)  ? xv : math.max(pMax, xv)
    [flMin, flMax, pMin, pMax]

f_lookupIdx(int[] tarr, int st, int en, int bt) =>
    int lo = st
    int hi = en
    int idx = st
    while lo <= hi
        int mid = int((lo + hi) / 2)
        if array.get(tarr, mid) <= bt
            idx := mid
            lo := mid + 1
        else
            hi := mid - 1
    idx

f_sample(int[] tarr, float[] call, float[] put, float[] price, int st, int en, int bt, float flMin, float flMax, float pMin, float pMax) =>
    float cV = na
    float pV = na
    float xV = na
    if st >= 0 and bt >= array.get(tarr, st) and bt <= array.get(tarr, en) + 1800000
        int idx = f_lookupIdx(tarr, st, en, bt)
        cV := array.get(call, idx)
        pV := array.get(put, idx)
        float raw = array.get(price, idx)
        if not na(pMin) and pMax > pMin and not na(flMin) and flMax > flMin
            xV := flMin + (raw - pMin) / (pMax - pMin) * (flMax - flMin)
    [cV, pV, xV]

